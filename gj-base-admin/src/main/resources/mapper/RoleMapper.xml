<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gj.llm.admin.mapper.RoleMapper">

    <!-- 结果映射：角色字段 -->
    <resultMap id="BaseResultMap" type="com.gj.llm.base.entity.RoleEntity">
        <id     column="id"          property="id"/>
        <result column="name"        property="name"/>
        <result column="code"        property="code"/>
        <result column="description" property="description"/>
        <result column="created_at"  property="createdAt"/>
    </resultMap>

    <!-- 根据编码查询角色 -->
    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT id, name, code, description, created_at
        FROM sys_role
        WHERE code = #{code}
    </select>

    <!-- 统计编码数量（唯一性校验） -->
    <select id="countByCode" resultType="int">
        SELECT COUNT(1) FROM sys_role WHERE code = #{code}
    </select>

    <!-- 根据用户 ID 查询该用户拥有的角色 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT r.id, r.name, r.code, r.description, r.created_at
        FROM sys_role r
        INNER JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>

</mapper>
